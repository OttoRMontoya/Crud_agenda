            function prop(obj, key) {
                if (!obj) return null;
                if (obj[key] !== undefined && obj[key] !== null) return obj[key];
                const pascal = key.charAt(0).toUpperCase() + key.slice(1);
                return obj[pascal];
            }

            function fillSelect(selectEl, items, selectedId, placeholder, labelFn, withEmpresa) {
                selectEl.innerHTML = '<option value="">' + placeholder + '</option>';
                (items || []).forEach(function (item) {
                    const opt = document.createElement('option');
                    const itemId = prop(item, 'id');
                    opt.value = itemId;
                    opt.textContent = labelFn(item);
                    if (withEmpresa) {
                        const empId = prop(item, 'empresaId');
                        if (empId) opt.setAttribute('data-empresa-id', empId);
                    }
                    if (selectedId && parseInt(selectedId) === parseInt(itemId)) opt.selected = true;
                    selectEl.appendChild(opt);
                });
            }

