            function postUpdateAppointment(appointment, dragExtras) {
                const inicio = toIsoFromDragPart(dragExtras.start);
                const fin = toIsoFromDragPart(dragExtras.end);
                if (!inicio || !fin) {
                    $calendar.bsCalendar('refresh');
                    return;
                }

                $.post(urls.updateDates, {
                    id: appointment.id,
                    inicio: inicio,
                    fin: fin,
                    todoelDia: !!appointment.allDay,
                    clinica: appointment.calendarId || null
                }, function (result) {
                    if (!result.success) {
                        alert(result.message || 'No se pudo actualizar.');
                        $calendar.bsCalendar('refresh');
                    } else if (result.data) {
                        navigateCalendarToAppointment(result.data);
                        applyAppointmentChange(result.data, {
                            isNew: false,
                            previousId: appointment.id,
                            previousCalendarId: appointment.calendarId,
                            previousStart: appointment.start
                        });
                    }
                }).fail(function () {
                    $calendar.bsCalendar('refresh');
                });
            }

