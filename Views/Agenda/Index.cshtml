            function fillForm(data, evtStart, evtEnd, evtAllDay) {
                document.getElementById('IdAgendaCita').value = data.IdAgendaCita || data.idAgendaCita || 0;
                document.getElementById('IdCalendario').value = data.IdCalendario || data.idCalendario || 1;
                document.getElementById('Codigo').value = data.Codigo || data.codigo || 0;
                document.getElementById('NoFichaIngreso').value = data.NoFichaIngreso || data.noFichaIngreso || 0;
                document.getElementById('Contacto').value = data.Contacto || data.contacto || '';
                document.getElementById('EMail').value = data.EMail || data.eMail || '';
                document.getElementById('Telefono1').value = data.Telefono1 || data.telefono1 || '';
                document.getElementById('Telefono2').value = data.Telefono2 || data.telefono2 || '';
                document.getElementById('Celular').value = data.Celular || data.celular || '';

                var inicioDate = evtStart ? parseDateValue(evtStart) : parseDateValue(data.Inicio || data.inicio);
                var finDate = evtEnd ? parseDateValue(evtEnd) : parseDateValue(data.Fin || data.fin);
                if (!finDate && inicioDate) {
                    finDate = new Date(inicioDate.getTime() + 60 * 60 * 1000);
                }
                var todoelDia = evtAllDay !== undefined && evtAllDay !== null
                    ? evtAllDay
                    : (data.TodoelDia || data.todoelDia || false);
                setFechaCampos(inicioDate, finDate, todoelDia);

                document.getElementById('Asunto').value = data.Asunto || data.asunto || '';
                document.getElementById('Descripcion').value = data.Descripcion || data.descripcion || '';
                document.getElementById('Lugar').value = data.Lugar || data.lugar || '';
                document.getElementById('Etiqueta').value = data.Etiqueta || data.etiqueta || 1;
                document.getElementById('Estatus').value = data.Estatus || data.estatus || 1;
                document.getElementById('EnviaRecordatorio').checked = data.EnviaRecordatorio || data.enviaRecordatorio || false;

                const codigoPaciente = data.Codigo || data.codigo || 0;
                if (codigoPaciente > 0) {
                    cargarPacientePorCodigo(codigoPaciente);
                } else {
                    document.getElementById('Codigo').value = '0';
                    document.getElementById('CodigoPacienteDisplay').value = '';
                    document.getElementById('pacienteSeleccionado').classList.add('d-none');
                }

                const empresaId = data.Empresa || data.empresa || '';
                const clinicaId = data.Clinica || data.clinica || '';
                const doctorId = data.CodigoDoctor || data.codigoDoctor || '';

                return loadEmpresas(empresaId).then(function () {
                    return loadClinicas(empresaId, clinicaId);
                }).then(function () {
                    return loadDoctores(empresaId, clinicaId, doctorId);
                });
            }

