@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@6.1.20/index.global.min.js"></script>
    @* <script src="https://cdn.jsdelivr.net/npm/@@fullcalendar/core@6.1.20/locales/es.global.min.js"></script>*@
    <script>
        (function () {
            const urls = {
                events: '@Url.Action("GetEvents", "Agenda")',
                save: '@Url.Action("SaveCita", "Agenda")',
                delete: '@Url.Action("DeleteCita", "Agenda")',
                updateDates: '@Url.Action("UpdateDates", "Agenda")',
                empresas: '@Url.Action("GetEmpresas", "Agenda")',
                clinicas: '@Url.Action("GetClinicas", "Agenda")',
                doctores: '@Url.Action("GetDoctores", "Agenda")',
                resources: '@Url.Action("GetResources", "Agenda")',
                doctoresFiltro: '@Url.Action("GetDoctoresFiltro", "Agenda")',
                clinicasFiltro: '@Url.Action("GetClinicasFiltro", "Agenda")',
                pacientesSearch: '@Url.Action("Search", "Pacientes")',
                pacienteGet: '@Url.Action("GetPaciente", "Pacientes")'
            };

            const selEmpresa = document.getElementById('Empresa');
            const selClinica = document.getElementById('Clinica');
            const selDoctor = document.getElementById('CodigoDoctor');
            //const filtroDoctor = document.getElementById('filtroDoctor');
            const filtroClinica = document.getElementById('filtroClinica');

            const etiquetaColors = {
                @foreach (var et in etiquetas)
                {
                    @:@et.Id: '@et.Color',
                }
            };

            const modalEl = document.getElementById('modalCita');
            const modal = new bootstrap.Modal(modalEl);
            const form = document.getElementById('formCita');
            const modalAlert = document.getElementById('modalAlert');
            const btnEliminar = document.getElementById('btnEliminarCita');
            const modalTitulo = document.getElementById('modalTitulo');
            let calendar;
            let calendarResources = [];

            function pad(n) { return n < 10 ? '0' + n : n; }

            function toLocalInputValue(date) {
                if (!date || isNaN(date.getTime())) return '';
                return date.getFullYear() + '-' + pad(date.getMonth() + 1) + '-' + pad(date.getDate()) +
                    'T' + pad(date.getHours()) + ':' + pad(date.getMinutes());
            }

            function parseDateValue(val) {
                if (!val) return null;
                if (val instanceof Date) return isNaN(val.getTime()) ? null : val;
                if (typeof val === 'string') {
                    var msMatch = val.match(/\/Date\((-?\d+)([+-]\d+)?\)\//);
                    if (msMatch) return new Date(parseInt(msMatch[1], 10));
                    var d = new Date(val);
                    return isNaN(d.getTime()) ? null : d;
                }
                return null;
            }

            function setFechaCampos(inicioDate, finDate, todoelDia) {
                if (inicioDate && !isNaN(inicioDate.getTime())) {
                    document.getElementById('Inicio').value = toLocalInputValue(inicioDate);
                }
                if (finDate && !isNaN(finDate.getTime())) {
                    document.getElementById('Fin').value = toLocalInputValue(finDate);
                }
                if (todoelDia !== undefined && todoelDia !== null) {
                    document.getElementById('TodoelDia').checked = !!todoelDia;
                }
            }

            function formatResourceDate(date) {
                return date.toLocaleDateString('es-GT', { weekday: 'long', day: 'numeric', month: 'long' });
            }

            function showAlert(message, isError) {
                modalAlert.textContent = message;
                modalAlert.classList.remove('d-none', 'alert-danger', 'alert-success');
                modalAlert.classList.add(isError ? 'alert-danger' : 'alert-success');
            }

            function hideAlert() {
                modalAlert.classList.add('d-none');
            }

            function prop(obj, key) {
                if (!obj) return null;
                if (obj[key] !== undefined && obj[key] !== null) return obj[key];
                const pascal = key.charAt(0).toUpperCase() + key.slice(1);
                return obj[pascal];
            }

            function fillSelect(selectEl, items, selectedId, placeholder, labelFn, withEmpresa) {
                selectEl.innerHTML = '<option value="">' + placeholder + '</option>';
                (items || []).forEach(function (item) {
                    const opt = document.createElement('option');
                    const itemId = prop(item, 'id');
                    opt.value = itemId;
                    opt.textContent = labelFn(item);
                    if (withEmpresa) {
                        const empId = prop(item, 'empresaId');
                        if (empId) opt.setAttribute('data-empresa-id', empId);
                    }
                    if (selectedId && parseInt(selectedId) === parseInt(itemId)) opt.selected = true;
                    selectEl.appendChild(opt);
                });
            }

            function loadEmpresas(selectedId) {
                return $.getJSON(urls.empresas).then(function (data) {
                    fillSelect(selEmpresa, data, selectedId, '-- Seleccione empresa --', function (x) { return prop(x, 'nombre'); });
                });
            }

            function loadClinicas(empresaId, selectedId) {
                if (!empresaId) {
                    fillSelect(selClinica, [], null, '-- Seleccione Habitación --', function (x) { return prop(x, 'nombre'); });
                    return $.Deferred().resolve().promise();
                }
                return $.getJSON(urls.clinicas, { empresaId: empresaId }).then(function (data) {
                    fillSelect(selClinica, data, selectedId, '-- Seleccione Habitación --', function (x) { return prop(x, 'nombre'); }, true);
                });
            }

            function loadDoctores(empresaId, clinicaId, selectedId) {
                const eId = empresaId || '';
                const cId = clinicaId || '';
                if (!eId && !cId) {
                    fillSelect(selDoctor, [], null, '-- Seleccione doctor --', function (x) { return prop(x, 'nombre'); });
                    return $.Deferred().resolve().promise();
                }
                return $.getJSON(urls.doctores, { empresaId: eId, clinicaId: cId }).then(function (data) {
                    fillSelect(selDoctor, data, selectedId, '-- Seleccione doctor --', function (x) {
                        const nombre = prop(x, 'nombre');
                        const esp = prop(x, 'especialidad');
                        return esp ? nombre + ' - ' + esp : nombre;
                    });
                });
            }

            //function loadDoctoresFiltro() {
            //    return $.getJSON(urls.doctoresFiltro).then(function (data) {
            //        fillSelect(filtroDoctor, data, null, '-- Todos los doctores --', function (x) {
            //            const nombre = prop(x, 'nombre');
            //            const esp = prop(x, 'especialidad');
            //            return esp ? nombre + ' - ' + esp : nombre;
            //        });
            //    });
            //}

            function loadClinicasFiltro() {
                return $.getJSON(urls.clinicasFiltro).then(function (data) {
                    fillSelect(filtroClinica, data, null, '-- Todas las Habitaciones --', function (x) { return prop(x, 'nombre'); });
                });
            }

            function getClinicaEmpresaId() {
                const opt = selClinica.options[selClinica.selectedIndex];
                if (opt && opt.getAttribute('data-empresa-id')) {
                    return opt.getAttribute('data-empresa-id');
                }
                return selEmpresa.value;
            }

            function preselectClinica(clinicaId) {
                if (!clinicaId) return $.Deferred().resolve().promise();

                function applyPreselect(empresaId) {
                    return loadEmpresas(empresaId).then(function () {
                        return loadClinicas(empresaId || selEmpresa.value, clinicaId);
                    }).then(function () {
                        const emp = selEmpresa.value || empresaId || getClinicaEmpresaId();
                        return loadDoctores(emp, clinicaId);
                    });
                }

                const resource = calendarResources.find(function (r) { return r.id == clinicaId; });
                const empresaFromResource = resource ? prop(resource, 'empresaId') : null;
                if (empresaFromResource) {
                    return applyPreselect(empresaFromResource);
                }

                return $.getJSON(urls.clinicas, {}).then(function (data) {
                    const clinica = (data || []).find(function (c) { return prop(c, 'id') == clinicaId; });
                    return applyPreselect(clinica ? prop(clinica, 'empresaId') : '');
                });
            }

            function limpiarPacienteSeleccion() {
                document.getElementById('Codigo').value = '0';
                document.getElementById('Contacto').value = '';
                document.getElementById('CodigoPacienteDisplay').value = '';
                document.getElementById('NoFichaIngreso').value = '0';
                document.getElementById('EMail').value = '';
                document.getElementById('Telefono1').value = '';
                document.getElementById('Telefono2').value = '';
                document.getElementById('Celular').value = '';
                document.getElementById('pacienteSeleccionado').classList.add('d-none');
                document.getElementById('pacienteSeleccionadoNombre').textContent = '';
            }

            function aplicarPaciente(p) {
                const codigo = prop(p, 'codigo');
                document.getElementById('Codigo').value = codigo || 0;
                document.getElementById('Contacto').value = prop(p, 'contacto') || prop(p, 'nombreCompleto') || '';
                document.getElementById('CodigoPacienteDisplay').value = prop(p, 'codigoPaciente') || '';
                document.getElementById('NoFichaIngreso').value = prop(p, 'noFichaIngreso') || 0;
                document.getElementById('EMail').value = prop(p, 'eMail') || prop(p, 'email') || '';
                document.getElementById('Telefono1').value = prop(p, 'telefono1') || '';
                document.getElementById('Telefono2').value = prop(p, 'telefono2') || '';
                document.getElementById('Celular').value = prop(p, 'celular') || '';
                document.getElementById('pacienteSeleccionadoNombre').textContent = prop(p, 'nombreCompleto') || prop(p, 'contacto') || '';
                document.getElementById('pacienteSeleccionado').classList.remove('d-none');
            }

            function renderListaPacientes(items) {
                const tbody = document.getElementById('listaPacientes');
                tbody.innerHTML = '';
                if (!items || items.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-muted text-center py-3">No se encontraron pacientes</td></tr>';
                    return;
                }
                items.forEach(function (p) {
                    const tr = document.createElement('tr');
                    tr.innerHTML =
                        '<td>' + (prop(p, 'codigoPaciente') || prop(p, 'codigo')) + '</td>' +
                        '<td>' + (prop(p, 'nombreCompleto') || '') + '</td>' +
                        '<td>' + (prop(p, 'noIdentificacion') || '-') + '</td>' +
                        '<td>' + (prop(p, 'celular') || prop(p, 'telefono1') || '-') + '</td>' +
                        '<td><button type="button" class="btn btn-primary btn-select-paciente">Seleccionar</button></td>';
                    tr.querySelector('.btn-select-paciente').addEventListener('click', function () {
                        aplicarPaciente(p);
                    });
                    tbody.appendChild(tr);
                });
            }

            function buscarPacientes() {
                const q = document.getElementById('buscarPaciente').value.trim();
                $.getJSON(urls.pacientesSearch, { q: q, limit: 30 }, function (data) {
                    renderListaPacientes(data);
                });
            }

            function cargarPacientePorCodigo(codigo) {
                if (!codigo || codigo <= 0) return $.Deferred().resolve().promise();
                return $.getJSON(urls.pacienteGet, { id: codigo }, function (result) {
                    if (result.success && result.data) {
                        aplicarPaciente(result.data);
                    }
                });
            }

            document.getElementById('btnBuscarPaciente').addEventListener('click', buscarPacientes);
            document.getElementById('buscarPaciente').addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); buscarPacientes(); }
            });
            document.getElementById('btnQuitarPaciente').addEventListener('click', limpiarPacienteSeleccion);

            document.querySelector('[data-bs-target="#tabContacto"]').addEventListener('shown.bs.tab', function () {
                if (document.getElementById('listaPacientes').rows.length <= 1) {
                    buscarPacientes();
                }
            });

            function resetForm() {
                form.reset();
                document.getElementById('IdAgendaCita').value = '0';
                document.getElementById('IdCalendario').value = '1';
                document.getElementById('Etiqueta').value = '1';
                document.getElementById('buscarPaciente').value = '';
                limpiarPacienteSeleccion();
                document.getElementById('listaPacientes').innerHTML = '<tr><td colspan="5" class="text-muted text-center py-3">Escriba y busque un paciente</td></tr>';
                hideAlert();
                btnEliminar.classList.add('d-none');
                modalTitulo.textContent = 'Nueva Reservación';
                new bootstrap.Tab(document.querySelector('#modalCita .nav-link')).show();
                loadEmpresas();
                loadClinicas(null);
                loadDoctores(null);
            }

            function fillForm(data, fcStart, fcEnd, fcAllDay) {
                document.getElementById('IdAgendaCita').value = data.IdAgendaCita || data.idAgendaCita || 0;
                document.getElementById('IdCalendario').value = data.IdCalendario || data.idCalendario || 1;
                document.getElementById('Codigo').value = data.Codigo || data.codigo || 0;
                document.getElementById('NoFichaIngreso').value = data.NoFichaIngreso || data.noFichaIngreso || 0;
                document.getElementById('Contacto').value = data.Contacto || data.contacto || '';
                document.getElementById('EMail').value = data.EMail || data.eMail || '';
                document.getElementById('Telefono1').value = data.Telefono1 || data.telefono1 || '';
                document.getElementById('Telefono2').value = data.Telefono2 || data.telefono2 || '';
                document.getElementById('Celular').value = data.Celular || data.celular || '';

                var inicioDate = fcStart ? new Date(fcStart) : parseDateValue(data.Inicio || data.inicio);
                var finDate = fcEnd ? new Date(fcEnd) : parseDateValue(data.Fin || data.fin);
                if (!finDate && inicioDate) {
                    finDate = new Date(inicioDate.getTime() + 60 * 60 * 1000);
                }
                var todoelDia = fcAllDay !== undefined && fcAllDay !== null
                    ? fcAllDay
                    : (data.TodoelDia || data.todoelDia || false);
                setFechaCampos(inicioDate, finDate, todoelDia);

                document.getElementById('Asunto').value = data.Asunto || data.asunto || '';
                document.getElementById('Descripcion').value = data.Descripcion || data.descripcion || '';
                document.getElementById('Lugar').value = data.Lugar || data.lugar || '';
                document.getElementById('Etiqueta').value = data.Etiqueta || data.etiqueta || 1;
                document.getElementById('Estatus').value = data.Estatus || data.estatus || 1;
                document.getElementById('EnviaRecordatorio').checked = data.EnviaRecordatorio || data.enviaRecordatorio || false;

                const codigoPaciente = data.Codigo || data.codigo || 0;
                if (codigoPaciente > 0) {
                    cargarPacientePorCodigo(codigoPaciente);
                } else {
                    document.getElementById('Codigo').value = '0';
                    document.getElementById('CodigoPacienteDisplay').value = '';
                    document.getElementById('pacienteSeleccionado').classList.add('d-none');
                }

                const empresaId = data.Empresa || data.empresa || '';
                const clinicaId = data.Clinica || data.clinica || '';
                const doctorId = data.CodigoDoctor || data.codigoDoctor || '';

                return loadEmpresas(empresaId).then(function () {
                    return loadClinicas(empresaId, clinicaId);
                }).then(function () {
                    return loadDoctores(empresaId, clinicaId, doctorId);
                });
            }

            function getFormData() {
                return {
                    IdAgendaCita: parseInt(document.getElementById('IdAgendaCita').value) || 0,
                    IdCalendario: parseInt(document.getElementById('IdCalendario').value) || 1,
                    Empresa: parseInt(document.getElementById('Empresa').value) || 0,
                    CodigoDoctor: parseInt(document.getElementById('CodigoDoctor').value) || 0,
                    Codigo: parseInt(document.getElementById('Codigo').value) || 0,
                    Clinica: parseInt(document.getElementById('Clinica').value) || 0,
                    NoFichaIngreso: parseInt(document.getElementById('NoFichaIngreso').value) || 0,
                    Contacto: document.getElementById('Contacto').value.trim(),
                    Inicio: document.getElementById('Inicio').value,
                    Fin: document.getElementById('Fin').value,
                    Asunto: document.getElementById('Asunto').value.trim(),
                    Descripcion: document.getElementById('Descripcion').value.trim(),
                    Lugar: document.getElementById('Lugar').value.trim(),
                    Etiqueta: parseInt(document.getElementById('Etiqueta').value) || 1,
                    Estatus: parseInt(document.getElementById('Estatus').value) || 1,
                    TodoelDia: document.getElementById('TodoelDia').checked,
                    Telefono1: document.getElementById('Telefono1').value.trim(),
                    Telefono2: document.getElementById('Telefono2').value.trim(),
                    Celular: document.getElementById('Celular').value.trim(),
                    EMail: document.getElementById('EMail').value.trim(),
                    EnviaRecordatorio: document.getElementById('EnviaRecordatorio').checked
                };
            }

            function openNewCita(start, end, allDay, clinicaId) {
                form.reset();
                document.getElementById('IdAgendaCita').value = '0';
                document.getElementById('IdCalendario').value = '1';
                document.getElementById('Etiqueta').value = '1';
                document.getElementById('buscarPaciente').value = '';
                limpiarPacienteSeleccion();
                document.getElementById('listaPacientes').innerHTML = '<tr><td colspan="5" class="text-muted text-center py-3">Escriba y busque un paciente</td></tr>';
                hideAlert();
                btnEliminar.classList.add('d-none');
                modalTitulo.textContent = 'Nueva Reservación';
                new bootstrap.Tab(document.querySelector('#modalCita .nav-link')).show();

                const startDate = start ? new Date(start) : new Date();
                let endDate = end ? new Date(end) : new Date(startDate.getTime() + 60 * 60 * 1000);

                if (allDay) {
                    startDate.setHours(0, 0, 0, 0);
                    endDate = new Date(startDate);
                    endDate.setDate(endDate.getDate() + 1);
                    document.getElementById('TodoelDia').checked = true;
                }

                document.getElementById('Inicio').value = toLocalInputValue(startDate);
                document.getElementById('Fin').value = toLocalInputValue(endDate);

                if (clinicaId) {
                    preselectClinica(clinicaId).always(function () { modal.show(); });
                } else {
                    loadEmpresas().then(function () {
                        loadClinicas(null);
                        return loadDoctores(null);
                    }).always(function () { modal.show(); });
                }
            }

            function openEditCita(props, fcStart, fcEnd, fcAllDay) {
                hideAlert();
                new bootstrap.Tab(document.querySelector('#modalCita .nav-link')).show();
                fillForm(props, fcStart, fcEnd, fcAllDay).then(function () {
                    modalTitulo.textContent = 'Editar Reservación';
                    btnEliminar.classList.remove('d-none');
                    modal.show();
                });
            }

            //function getSelectedDoctorFilter() {
            //    const val = filtroDoctor.value;
            //    return val ? parseInt(val) : '';
            //}

            function getSelectedClinicaFilter() {
                const val = filtroClinica.value;
                return val ? val.toString() : '';
            }

            function refetchCalendar() {
                calendar.refetchResources();
                calendar.refetchEvents();
            }

            function postUpdateEvent(info) {
                const endDate = info.event.end || info.event.start;
                const newResource = info.newResource || (info.event.getResources && info.event.getResources()[0]);
                const clinicaId = newResource ? newResource.id : null;

                $.post(urls.updateDates, {
                    id: info.event.id,
                    inicio: info.event.start.toISOString(),
                    fin: endDate.toISOString(),
                    todoelDia: info.event.allDay,
                    clinica: clinicaId
                }, function (result) {
                    if (!result.success) {
                        alert(result.message || 'No se pudo actualizar.');
                        info.revert();
                    }
                }).fail(function () {
                    info.revert();
                });
            }

            selEmpresa.addEventListener('change', function () {
                const empresaId = this.value;
                loadClinicas(empresaId).then(function () {
                    loadDoctores(empresaId, selClinica.value);
                });
            });

            selClinica.addEventListener('change', function () {
                const clinicaId = this.value;
                const empresaFromClinica = getClinicaEmpresaId();
                if (empresaFromClinica && !selEmpresa.value) {
                    selEmpresa.value = empresaFromClinica;
                }
                loadDoctores(selEmpresa.value || empresaFromClinica, clinicaId);
            });

            //filtroDoctor.addEventListener('change', function () {
            //    calendar.refetchEvents();
            //});

            filtroClinica.addEventListener('change', function () {
                refetchCalendar();
            });

            document.getElementById('btnNuevaCita').addEventListener('click', function () {
                openNewCita(calendar.getDate(), null, false, null);
            });

            document.getElementById('btnGuardarCita').addEventListener('click', function () {
                hideAlert();
                const data = getFormData();

                if (!data.Asunto) { showAlert('El asunto es requerido.', true); return; }
                if (!data.Contacto) { showAlert('Debe seleccionar un paciente.', true); return; }
                if (!data.Codigo) { showAlert('Debe seleccionar un paciente de la lista.', true); return; }
                if (!data.Empresa) { showAlert('Debe seleccionar una empresa.', true); return; }
                if (!data.Clinica) { showAlert('Debe seleccionar una clínica.', true); return; }

                $.ajax({
                    url: urls.save,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    success: function (result) {
                        if (result.success) {
                            modal.hide();
                            calendar.refetchEvents();
                        } else {
                            showAlert(result.message || 'Error al guardar.', true);
                        }
                    },
                    error: function () {
                        showAlert('Error de comunicación con el servidor.', true);
                    }
                });
            });

            btnEliminar.addEventListener('click', function () {
                const id = parseInt(document.getElementById('IdAgendaCita').value);
                if (!id || !confirm('¿Está seguro de eliminar esta Reservación?')) return;

                $.post(urls.delete, { id: id }, function (result) {
                    if (result.success) {
                        modal.hide();
                        calendar.refetchEvents();
                    } else {
                        showAlert(result.message || 'Error al eliminar.', true);
                    }
                });
            });

            document.getElementById('TodoelDia').addEventListener('change', function () {
                const inicio = document.getElementById('Inicio');
                const fin = document.getElementById('Fin');
                if (this.checked) {
                    const d = new Date(inicio.value);
                    d.setHours(0, 0, 0, 0);
                    inicio.value = toLocalInputValue(d);
                    const dEnd = new Date(d);
                    dEnd.setDate(dEnd.getDate() + 1);
                    fin.value = toLocalInputValue(dEnd);
                }
            });

            const calendarEl = document.getElementById('calendar');
            calendar = new FullCalendar.Calendar(calendarEl, {
                locale: 'es',
                initialView: 'resourceTimeGridDay',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'resourceTimeGridDay,timeGridWeek,dayGridMonth,listWeek'
                },
                buttonText: {
                    today: 'Hoy',
                    resourceTimeGridDay: 'Día',
                    timeGridWeek: 'Semana',
                    dayGridMonth: 'Mes',
                    listWeek: 'Lista'
                },
                views: {
                    resourceTimeGridDay: {
                        type: 'resourceTimeGrid',
                        duration: { days: 1 },
                        slotMinTime: '06:00:00',
                        slotMaxTime: '22:00:00',
                        slotDuration: '00:30:00',
                        allDaySlot: false
                    },
                    timeGridWeek: {
                        slotMinTime: '06:00:00',
                        slotMaxTime: '22:00:00',
                        slotDuration: '00:30:00',
                        allDaySlot: false
                    }
                },
                editable: true,
                selectable: true,
                selectMirror: true,
                nowIndicator: true,
                height: 'auto',
                resourceOrder: 'title',
                resources: function (fetchInfo, successCallback, failureCallback) {
                    $.getJSON(urls.resources, function (data) {
                        calendarResources = data || [];
                        const filtro = getSelectedClinicaFilter();
                        const list = filtro
                            ? calendarResources.filter(function (r) { return r.id == filtro; })
                            : calendarResources;
                        successCallback(list);
                    }).fail(function () {
                        failureCallback();
                    });
                },
                resourceLabelContent: function (arg) {
                    const dateStr = formatResourceDate(calendar.getDate());
                    return {
                        html: '<div class="resource-clinic-name">' + arg.resource.title + '</div>' +
                              '<div class="resource-clinic-date">' + dateStr + '</div>'
                    };
                },
                resourceLabelDidMount: function (arg) {
                    arg.el.classList.add('fc-resource-header');
                },
                events: function (info, successCallback, failureCallback) {
                    $.ajax({
                        url: urls.events,
                        data: {
                            start: info.startStr,
                            end: info.endStr,
                           // codigoDoctor: getSelectedDoctorFilter(),
                            clinica: filtroClinica.value || ''
                        },
                        success: function (data) {
                            successCallback(data);
                        },
                        error: function () {
                            failureCallback();
                        }
                    });
                },
                select: function (info) {
                    const clinicaId = info.resource
                        ? info.resource.id
                        : (filtroClinica.value || null);
                    openNewCita(info.start, info.end, info.allDay, clinicaId);
                    calendar.unselect();
                },
                eventClick: function (info) {
                    if (info.event.extendedProps) {
                        openEditCita(
                            info.event.extendedProps,
                            info.event.start,
                            info.event.end,
                            info.event.allDay
                        );
                    }
                },
                eventDrop: postUpdateEvent,
                eventResize: postUpdateEvent,
                eventDidMount: function (info) {
                    const props = info.event.extendedProps || {};
                    const etiqueta = props.Etiqueta || props.etiqueta;
                    if (etiqueta && etiquetaColors[etiqueta]) {
                        info.el.style.backgroundColor = etiquetaColors[etiqueta];
                        info.el.style.borderColor = etiquetaColors[etiqueta];
                    }
                },
                resourceLaneDidMount: function (arg) {
                    const idx = arg.resource.getIndex();
                    arg.el.classList.add(idx % 2 === 0 ? 'resource-col-even' : 'resource-col-odd');
                }
            });

            calendar.render();
            loadClinicasFiltro();
            //loadDoctoresFiltro();
            modalEl.addEventListener('hidden.bs.modal', resetForm);
        })();
    </script>
}
