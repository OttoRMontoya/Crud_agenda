@using Crud_agenda.Models
@{
    ViewBag.Title = "Sistema de Reservaciones";
    var estatusList = ViewBag.EstatusList as List<AgendaEstatus> ?? new List<AgendaEstatus>();
    var etiquetas = ViewBag.Etiquetas as List<EtiquetaOption> ?? AgendaEtiquetas.Opciones;
}

<div class="calendar-page">
    <div class="calendar-header mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <h2 class="calendar-title mb-1">
                    <i class="bi bi-calendar3"></i> Sistema de Reservaciones
                </h2>
                <p class="text-muted mb-0">Vista diaria por habitación — seleccione un horario en la columna de la habitación deseada</p>
            </div>
            <button type="button" class="btn btn-primary btn-lg" id="btnNuevaCita">
                <i class="bi bi-plus-lg"></i> Nueva Reservación
            </button>
        </div>
    </div>

    <div class="card calendar-card">
        <div class="card-body p-3">
            <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
                <div class="etiquetas-leyenda">
                    @foreach (var et in etiquetas)
                    {
                        <span class="leyenda-item">
                            <span class="leyenda-color" style="background-color: @et.Color;"></span>
                            @et.Nombre
                        </span>
                    }
                </div>
                <div class="calendar-filters d-flex flex-wrap gap-3">
                    <div>
                        <label class="form-label mb-1" for="filtroClinica">
                            <i class="bi bi-hospital"></i> Filtrar por habitación
                        </label>
                        <select id="filtroClinica" class="form-select form-select-sm">
                            <option value="">-- Todas las habitaciones --</option>
                        </select>
                    </div>
                    @*<div>
                        <label class="form-label mb-1" for="filtroDoctor">
                            <i class="bi bi-person-badge"></i> Filtrar por doctor
                        </label>
                        <select id="filtroDoctor" class="form-select form-select-sm">
                            <option value="">-- Todos los doctores --</option>
                        </select>
                    </div>*@
                </div>
            </div>
            <div id="calendar"></div>
        </div>
    </div>
</div>

<!-- Modal Reservación -->
<div class="modal fade" id="modalCita" tabindex="-1" aria-labelledby="modalCitaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-gradient">
                <h5 class="modal-title" id="modalCitaLabel">
                    <i class="bi bi-calendar-plus"></i> <span id="modalTitulo">Nueva Reservación</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalAlert" class="alert alert-danger d-none" role="alert"></div>
                <form id="formCita">
                    <input type="hidden" id="IdAgendaCita" name="IdAgendaCita" value="0" />

                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabCita" type="button">Reservación</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabContacto" type="button">Contacto</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabMedico" type="button">Datos Extras</button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tabCita">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label">Asunto <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="Asunto" name="Asunto" maxlength="50" required placeholder="Ej: Reservación general" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Etiqueta</label>
                                    <select class="form-select" id="Etiqueta" name="Etiqueta">
                                        @foreach (var et in etiquetas)
                                        {
                                            <option value="@et.Id">@et.Nombre</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Inicio <span class="text-danger">*</span></label>
                                    <input type="datetime-local" class="form-control" id="Inicio" name="Inicio" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Fin <span class="text-danger">*</span></label>
                                    <input type="datetime-local" class="form-control" id="Fin" name="Fin" required />
                                </div>
                                <div class="col-md-4 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="TodoelDia" name="TodoelDia" />
                                        <label class="form-check-label" for="TodoelDia">Todo el día</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Lugar</label>
                                    <input type="text" class="form-control" id="Lugar" name="Lugar" maxlength="50" placeholder="Habitación, sala, etc." />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Estatus</label>
                                    <select class="form-select" id="Estatus" name="Estatus">
                                        @if (estatusList.Any())
                                        {
                                            foreach (var est in estatusList)
                                            {
                                                <option value="@est.IdEstatus">@est.NombreEstatus</option>
                                            }
                                        }
                                        else
                                        {
                                            <option value="1">Pendiente</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Descripción</label>
                                    <textarea class="form-control" id="Descripcion" name="Descripcion" rows="3" maxlength="250" placeholder="Notas adicionales de la Reservación..."></textarea>
                                </div>
                                <div class="col-12">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="EnviaRecordatorio" name="EnviaRecordatorio" />
                                        <label class="form-check-label" for="EnviaRecordatorio">Enviar recordatorio</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="tabContacto">
                            <input type="hidden" id="Codigo" name="Codigo" value="0" />

                            <div class="mb-3">
                                <label class="form-label" for="buscarPaciente">
                                    <i class="bi bi-search"></i> Buscar cliente para asociar a la reservación
                                </label>
                                <div class="input-group">
                                    <input type="text" class="form-control" id="buscarPaciente" placeholder="Nombre, código, identificación, teléfono o correo..." />
                                    <button type="button" class="btn btn-primary" id="btnBuscarPaciente">Buscar</button>
                                </div>
                            </div>

                            <div id="listaPacientesWrap" class="table-responsive patient-list-wrap mb-3">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Cód.</th>
                                            <th>Cliente</th>
                                            <th>Identificación</th>
                                            <th>Teléfono</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody id="listaPacientes">
                                        <tr><td colspan="5" class="text-muted text-center py-3">Escriba y busque un cliente</td></tr>
                                    </tbody>
                                </table>
                            </div>

                            <div id="pacienteSeleccionado" class="alert alert-success d-none py-2 mb-3">
                                <i class="bi bi-person-check"></i>
                                Cliente seleccionado: <strong id="pacienteSeleccionadoNombre"></strong>
                                <button type="button" class="btn btn-sm btn-outline-secondary ms-2" id="btnQuitarPaciente">Quitar</button>
                            </div>

                            <hr class="my-3" />
                            <p class="text-muted small mb-2">Datos de contacto (se llenan al seleccionar cliente)</p>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Contacto / Cliente <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="Contacto" name="Contacto" maxlength="100" required readonly />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Cód. Cliente</label>
                                    <input type="text" class="form-control" id="CodigoPacienteDisplay" readonly />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">No. Ficha Ingreso</label>
                                    <input type="number" class="form-control" id="NoFichaIngreso" name="NoFichaIngreso" value="0" min="0" readonly />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Correo electrónico</label>
                                    <input type="email" class="form-control" id="EMail" name="EMail" maxlength="100" readonly />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Teléfono 1</label>
                                    <input type="text" class="form-control" id="Telefono1" name="Telefono1" maxlength="12" readonly />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Teléfono 2 (Trabajo)</label>
                                    <input type="text" class="form-control" id="Telefono2" name="Telefono2" maxlength="12" readonly />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Celular</label>
                                    <input type="text" class="form-control" id="Celular" name="Celular" maxlength="12" readonly />
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="tabMedico">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">Empresa <span class="text-danger">*</span></label>
                                    <select class="form-select" id="Empresa" name="Empresa" required>
                                        <option value="">-- Seleccione empresa --</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Habitación <span class="text-danger">*</span></label>
                                    <select class="form-select" id="Clinica" name="Clinica" required>
                                        <option value="">-- Seleccione habitación --</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Doctor</label>
                                    <select class="form-select" id="CodigoDoctor" name="CodigoDoctor">
                                        <option value="">-- Seleccione doctor --</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                   @* <label class="form-label">Id Calendario</label>*@
                                    <input type="hidden" class="form-control" id="IdCalendario" name="IdCalendario" value="1" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-outline-danger d-none" id="btnEliminarCita">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
                <div class="ms-auto d-flex gap-2">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarCita">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

