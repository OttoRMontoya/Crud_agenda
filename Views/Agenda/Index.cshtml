            });

            selClinica.addEventListener('change', function () {
                const clinicaId = this.value;
                const empresaFromClinica = getClinicaEmpresaId();
                if (empresaFromClinica && !selEmpresa.value) {
                    selEmpresa.value = empresaFromClinica;
                }
                loadDoctores(selEmpresa.value || empresaFromClinica, clinicaId);
            });

            //filtroDoctor.addEventListener('change', function () {
            //    calendar.refetchEvents();
            //});

            filtroClinicaList.addEventListener('change', function (e) {
                if (e.target.matches('input[type="checkbox"]')) {
                    onFiltroClinicaChanged();
                }
            });

            document.getElementById('filtroClinicaTodas').addEventListener('click', function (e) {
                e.preventDefault();
                setAllFiltroClinicas(true);
                syncCalendarsAndRefresh();
            });

            document.getElementById('filtroClinicaNinguna').addEventListener('click', function (e) {
                e.preventDefault();
                setAllFiltroClinicas(false);
                syncCalendarsAndRefresh();
            });

            document.getElementById('btnNuevaCita').addEventListener('click', function () {
                openNewCita(new Date(), null, false, getDefaultClinicaForNewCita());
            });

            document.getElementById('btnGuardarCita').addEventListener('click', function () {
                hideAlert();
                const data = getFormData();
                const wasNew = !(parseInt(document.getElementById('IdAgendaCita').value, 10) > 0);

                if (!data.Asunto) { showAlert('El asunto es requerido.', true); return; }
                if (!data.Contacto) { showAlert('Debe seleccionar un paciente.', true); return; }
                if (!data.Codigo) { showAlert('Debe seleccionar un paciente de la lista.', true); return; }
                if (!data.Empresa) { showAlert('Debe seleccionar una empresa.', true); return; }
                if (!data.Clinica) { showAlert('Debe seleccionar una clínica.', true); return; }

                $.ajax({
                    url: urls.save,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    success: function (result) {
                        if (result.success) {
                            onCitaSaved(result, wasNew);
                        } else {
                            showAlert(result.message || 'Error al guardar.', true);
                        }
                    },
                    error: function () {
                        showAlert('Error de comunicación con el servidor.', true);
                    }
                });
            });

            btnEliminar.addEventListener('click', function () {
                const id = parseInt(document.getElementById('IdAgendaCita').value);
                if (!id || !confirm('¿Está seguro de eliminar esta Reservación?')) return;

                const deleteMeta = {
                    calendarId: document.getElementById('Clinica').value,
                    start: document.getElementById('Inicio').value
                };

                $.post(urls.delete, { id: id }, function (result) {
                    if (result.success) {
                        modal.hide();
                        removeAppointmentFromCalendar(id, deleteMeta);
                    } else {
                        showAlert(result.message || 'Error al eliminar.', true);
                    }
                });
            });

            document.getElementById('TodoelDia').addEventListener('change', function () {
                const inicio = document.getElementById('Inicio');
                const fin = document.getElementById('Fin');
                if (this.checked) {
                    const d = new Date(inicio.value);
                    d.setHours(0, 0, 0, 0);
                    inicio.value = toLocalInputValue(d);
                    const dEnd = new Date(d);
                    dEnd.setDate(dEnd.getDate() + 1);
                    fin.value = toLocalInputValue(dEnd);
                }
            });

            function initBsCalendar(initialView) {
                if (bsCalendarReady) return;
                $calendar.bsCalendar({
                    locale: 'es',
                    title: 'Sistema de Reservaciones',
                    startView: initialView || 'week',
                    startDate: roomsDayState.currentDate,
                    views: ['week', 'month', 'agenda'],
                    mainColor: 'primary',
                    storeState: false,
                    ingoreStore: true,
                    showAddButton: true,
                    draggable: true,
                    draggableSnapMinutes: 30,
                    hourSlots: {
                        start: 6,
                        end: 22,
                        height: 30
                    },
                    url: fetchEventsForBsCalendar,
                    onAdd: function (payload) {
                        const start = parsePayloadDate(payload.start);
                        const end = parsePayloadDate(payload.end);
                        openNewCita(start, end, false, getDefaultClinicaForNewCita());
                    },
                    onEdit: function (appointment, extras, dragExtras) {
                        if (dragExtras && dragExtras.hourSlotRules) {
                            postUpdateAppointment(appointment, dragExtras);
                            return;
                        }
                        const props = appointment.cita || {};
                        openEditCita(props, appointment.start, appointment.end, appointment.allDay);
                    },
                    onDelete: function (appointment) {
                        const id = parseInt(appointment.id, 10);
                        if (!id || !confirm('¿Está seguro de eliminar esta Reservación?')) {
                            $calendar.bsCalendar('refresh');
                            return;
                        }
                        $.post(urls.delete, { id: id }, function (result) {
                            if (!result.success) {
                                alert(result.message || 'Error al eliminar.');
                                $calendar.bsCalendar('refresh');
                            } else {
                                removeAppointmentFromCalendar(id, {
                                    calendarId: appointment.calendarId,
                                    start: appointment.start
                                });
                            }
                        }).fail(function () {
                            $calendar.bsCalendar('refresh');
                        });
                    },
                    onNavigateForward: function () {
                        syncBsCalendarDateToRooms();
                    },
                    onNavigateBack: function () {
                        syncBsCalendarDateToRooms();
                    },
                    onView: function () {
                        syncBsCalendarDateToRooms();
                    }
                });
                bsCalendarReady = true;
            }

            function syncBsCalendarDateToRooms() {
                try {
                    const data = $calendar.data('bsCalendar');
                    if (data && data.date) {
                        roomsDayState.currentDate = new Date(data.date.getTime());
                    }
                } catch (e) { /* ignore */ }
            }

            document.querySelector('.calendar-view-switcher').addEventListener('click', function (e) {
                const btn = e.target.closest('[data-calendar-view]');
                if (!btn) return;
                setCalendarView(btn.getAttribute('data-calendar-view'));
            });

            document.getElementById('roomsDayPrev').addEventListener('click', function () { navigateRoomsDay(-1); });
            document.getElementById('roomsDayNext').addEventListener('click', function () { navigateRoomsDay(1); });
            document.getElementById('roomsDayToday').addEventListener('click', function () {
                roomsDayState.currentDate = new Date();
                renderRoomsDayView();
            });

            bindRoomsDayGridEvents();

            loadCalendarResources().then(function () {
                return loadClinicasFiltro();
            }).then(function () {
                setCalendarView('rooms-day');
            });

            modalEl.addEventListener('hidden.bs.modal', resetForm);
        })();
    </script>
}
