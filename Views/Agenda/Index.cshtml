            function preselectClinica(clinicaId) {
                if (!clinicaId) return $.Deferred().resolve().promise();

                function applyPreselect(empresaId) {
                    return loadEmpresas(empresaId).then(function () {
                        return loadClinicas(empresaId || selEmpresa.value, clinicaId);
                    }).then(function () {
                        const emp = selEmpresa.value || empresaId || getClinicaEmpresaId();
                        return loadDoctores(emp, clinicaId);
                    });
                }

                const resource = calendarResources.find(function (r) { return r.id == clinicaId; });
                const empresaFromResource = resource ? prop(resource, 'empresaId') : null;
                if (empresaFromResource) {
                    return applyPreselect(empresaFromResource);
                }

                return $.getJSON(urls.clinicas, {}).then(function (data) {
                    const clinica = (data || []).find(function (c) { return prop(c, 'id') == clinicaId; });
                    return applyPreselect(clinica ? prop(clinica, 'empresaId') : '');
                });
            }

