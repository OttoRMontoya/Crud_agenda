@model Crud_agenda.Models.Paciente

<div class="row g-3">
    <div class="col-md-3">
        @Html.LabelFor(m => m.CodigoPaciente, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.CodigoPaciente, new { @class = "form-control", maxlength = "15" })
        @Html.ValidationMessageFor(m => m.CodigoPaciente, "", new { @class = "text-danger small" })
    </div>
    <div class="col-md-3">
        @Html.LabelFor(m => m.PrimerNombre, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.PrimerNombre, new { @class = "form-control", maxlength = "50" })
        @Html.ValidationMessageFor(m => m.PrimerNombre, "", new { @class = "text-danger small" })
    </div>
    <div class="col-md-3">
        @Html.LabelFor(m => m.SegundoNombre, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.SegundoNombre, new { @class = "form-control", maxlength = "50" })
    </div>
    <div class="col-md-3">
        @Html.LabelFor(m => m.PrimerApellido, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.PrimerApellido, new { @class = "form-control", maxlength = "50" })
        @Html.ValidationMessageFor(m => m.PrimerApellido, "", new { @class = "text-danger small" })
    </div>
    <div class="col-md-3">
        @Html.LabelFor(m => m.SegundoApellido, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.SegundoApellido, new { @class = "form-control", maxlength = "50" })
    </div>
    <div class="col-md-3">
        @Html.LabelFor(m => m.ApellidoCasada, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.ApellidoCasada, new { @class = "form-control", maxlength = "50" })
    </div>
    <div class="col-md-3">
        @Html.LabelFor(m => m.FechaNacimiento, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.FechaNacimiento, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
    </div>
    <div class="col-md-3">
        @Html.LabelFor(m => m.NoIdentificacion, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.NoIdentificacion, new { @class = "form-control", maxlength = "30" })
    </div>
    <div class="col-md-4">
        @Html.LabelFor(m => m.Telefono, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", maxlength = "12" })
    </div>
    <div class="col-md-4">
        @Html.LabelFor(m => m.Celular, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Celular, new { @class = "form-control", maxlength = "12" })
    </div>
    <div class="col-md-4">
        @Html.LabelFor(m => m.TelefonoTrabajo, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.TelefonoTrabajo, new { @class = "form-control", maxlength = "12" })
    </div>
    <div class="col-md-6">
        @Html.LabelFor(m => m.EMail, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.EMail, new { @class = "form-control", maxlength = "100", type = "email" })
    </div>
    <div class="col-md-6">
        @Html.LabelFor(m => m.Direccion1, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Direccion1, new { @class = "form-control", maxlength = "60" })
    </div>
    <div class="col-md-6">
        @Html.LabelFor(m => m.ResponsableCuenta, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.ResponsableCuenta, new { @class = "form-control", maxlength = "200" })
    </div>
</div>
