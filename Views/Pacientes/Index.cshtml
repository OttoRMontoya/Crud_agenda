@model List<Crud_agenda.Models.Paciente>
@{ ViewBag.Title = "Clientes"; }

<div class="card">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
        <h5 class="mb-0"><i class="bi bi-people"></i> Clientes</h5>
        @Html.ActionLink("Nuevo Cliente", "Create", null, new { @class = "btn btn-light btn-sm" })
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Index", "Pacientes", FormMethod.Get, new { @class = "row g-2 mb-3" }))
        {
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" class="form-control" value="@ViewBag.Search" placeholder="Buscar por nombre, código, identificación, teléfono o correo..." />
                    <button type="submit" class="btn btn-primary">Buscar</button>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                    {
                        @Html.ActionLink("Limpiar", "Index", null, new { @class = "btn btn-outline-secondary" })
                    }
                </div>
            </div>
        }

        @if (Model.Count == 0)
        {
            <div class="alert alert-info mb-0">
                No se encontraron pacientes.
                @if (string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    @Html.ActionLink("Registrar uno", "Create")
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Cód. Cliente</th>
                            <th>Nombre</th>
                            <th>Identificación</th>
                            <th>Teléfono</th>
                            <th>Celular</th>
                            <th>Correo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@item.Codigo</span></td>
                                <td>@item.CodigoPaciente.Trim()</td>
                                <td>@item.NombreCompleto</td>
                                <td>@(string.IsNullOrWhiteSpace(item.NoIdentificacion) ? "-" : item.NoIdentificacion.Trim())</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Telefono) ? "-" : item.Telefono.Trim())</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Celular) ? "-" : item.Celular.Trim())</td>
                                <td>@(string.IsNullOrWhiteSpace(item.EMail) ? "-" : item.EMail.Trim())</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        @Html.ActionLink("Ver", "Details", new { id = item.Codigo }, new { @class = "btn btn-info" })
                                        @Html.ActionLink("Editar", "Edit", new { id = item.Codigo }, new { @class = "btn btn-warning" })
                                        @Html.ActionLink("Eliminar", "Delete", new { id = item.Codigo }, new { @class = "btn btn-danger" })
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
