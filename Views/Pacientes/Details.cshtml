@model Crud_agenda.Models.Paciente
@{ ViewBag.Title = "Detalle Cliente"; }

<div class="row"><div class="col-lg-8 offset-lg-2">
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-person"></i> @Model.NombreCompleto</h5>
        <div>
            @Html.ActionLink("Editar", "Edit", new { id = Model.Codigo }, new { @class = "btn btn-warning btn-sm" })
            @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary btn-sm" })
        </div>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Código interno</dt><dd class="col-sm-8">@Model.Codigo</dd>
            <dt class="col-sm-4">Código Cliente</dt><dd class="col-sm-8">@Model.CodigoPaciente.Trim()</dd>
            <dt class="col-sm-4">Identificación</dt><dd class="col-sm-8">@(Model.NoIdentificacion?.Trim() ?? "-")</dd>
            <dt class="col-sm-4">Fecha nacimiento</dt><dd class="col-sm-8">@(Model.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "-")</dd>
            <dt class="col-sm-4">Teléfono</dt><dd class="col-sm-8">@(Model.Telefono?.Trim() ?? "-")</dd>
            <dt class="col-sm-4">Celular</dt><dd class="col-sm-8">@(Model.Celular?.Trim() ?? "-")</dd>
            <dt class="col-sm-4">Tel. trabajo</dt><dd class="col-sm-8">@(Model.TelefonoTrabajo?.Trim() ?? "-")</dd>
            <dt class="col-sm-4">Correo</dt><dd class="col-sm-8">@(Model.EMail?.Trim() ?? "-")</dd>
            <dt class="col-sm-4">Dirección</dt><dd class="col-sm-8">@(Model.Direccion1?.Trim() ?? "-")</dd>
            <dt class="col-sm-4">Responsable cuenta</dt><dd class="col-sm-8">@(Model.ResponsableCuenta?.Trim() ?? "-")</dd>
        </dl>
    </div>
</div></div></div>
