@model Crud_agenda.Models.Paciente
@{ ViewBag.Title = "Editar Paciente"; }

<div class="row"><div class="col-lg-10 offset-lg-1">
<div class="card">
    <div class="card-header"><h5 class="mb-0"><i class="bi bi-pencil"></i> Editar Paciente</h5></div>
    <div class="card-body">
        @using (Html.BeginForm("Edit", "Pacientes", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Codigo)
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
            @Html.Partial("_FormPaciente", Model)
            <button type="submit" class="btn btn-primary">Guardar</button>
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary" })
        }
    </div>
</div></div></div>
