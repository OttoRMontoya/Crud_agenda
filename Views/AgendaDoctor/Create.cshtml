@model Crud_agenda.Models.AgendaDoctor
@{ ViewBag.Title = "Nuevo Doctor"; }

<div class="row"><div class="col-md-8 offset-md-2">
<div class="card">
    <div class="card-header"><h5 class="mb-0"><i class="bi bi-plus-circle"></i> Nuevo Doctor</h5></div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "AgendaDoctor", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
            <div class="mb-3">
                @Html.LabelFor(m => m.IdEmpresa, new { @class = "form-label" })
                @Html.DropDownListFor(m => m.IdEmpresa, (SelectList)ViewBag.IdEmpresa, "-- Seleccione --", new { @class = "form-select", id = "IdEmpresa" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.IdClinica, new { @class = "form-label" })
                @Html.DropDownListFor(m => m.IdClinica, (SelectList)ViewBag.IdClinica, "-- Todas / Sin asignar --", new { @class = "form-select", id = "IdClinica" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.NombreDoctor, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.NombreDoctor, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.NombreDoctor, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Especialidad, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Especialidad, new { @class = "form-control", placeholder = "Ej: Cardiología" })
            </div>
            <button type="submit" class="btn btn-primary">Guardar</button>
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary" })
        }
    </div>
</div></div></div>

@section scripts {
<script>
    $('#IdEmpresa').change(function () {
        var id = $(this).val();
        var $clinica = $('#IdClinica');
        $clinica.empty().append('<option value="">-- Todas / Sin asignar --</option>');
        if (!id) return;
        $.getJSON('@Url.Action("GetClinicasByEmpresa", "AgendaDoctor")', { empresaId: id }, function (data) {
            data.forEach(function (c) { $clinica.append('<option value="' + c.id + '">' + c.nombre + '</option>'); });
        });
    });
</script>
}
