@model Crud_agenda.Models.AgendaDoctor
@{ ViewBag.Title = "Eliminar Doctor"; }

<div class="row"><div class="col-md-6 offset-md-3">
<div class="card border-danger">
    <div class="card-header bg-danger text-white"><h5 class="mb-0">Confirmar eliminación</h5></div>
    <div class="card-body">
        <p>¿Eliminar al doctor <strong>@Model.NombreDoctor</strong>?</p>
        @using (Html.BeginForm("Delete", "AgendaDoctor", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.CodigoDoctor)
            <button type="submit" class="btn btn-danger">Eliminar</button>
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary" })
        }
    </div>
</div></div></div>
