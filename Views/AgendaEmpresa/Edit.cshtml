@model Crud_agenda.Models.AgendaEmpresa
@{ ViewBag.Title = "Editar Empresa"; }

<div class="row"><div class="col-md-8 offset-md-2">
<div class="card">
    <div class="card-header"><h5 class="mb-0"><i class="bi bi-pencil"></i> Editar Empresa</h5></div>
    <div class="card-body">
        @using (Html.BeginForm("Edit", "AgendaEmpresa", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.IdEmpresa)
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
            <div class="mb-3">
                @Html.LabelFor(m => m.NombreEmpresa, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.NombreEmpresa, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.NombreEmpresa, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3 form-check">
                @Html.CheckBoxFor(m => m.Activo, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.Activo, new { @class = "form-check-label" })
            </div>
            <button type="submit" class="btn btn-primary">Guardar</button>
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary" })
        }
    </div>
</div></div></div>
